# Seed3D / 火山方舟 API key. 用于 seed3D/seed3D.py 调用 Seed3D 2.0 接口。
ARK_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书 Bot 凭据。pipeline.py / feishu_watcher.py 用来推送文本/卡片/文件回飞书。
# 不设置时 FeishuNotifier 自动降级为 no-op（产物仍落盘）。
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 单次直跑 pipeline.py 时用到的接收方信息。watcher 模式下不需要。
FEISHU_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxx
FEISHU_RECEIVE_ID_TYPE=open_id

# 把 Seed3D 产物通过临时 HTTP server 暴露给飞书时拼装的对外地址 (host:port)。
# 部署到 ECS 时改成对外 IP/域名；本地调试用默认 127.0.0.1 即可。
SEED3D_PUBLIC_HOST=127.0.0.1:8888
